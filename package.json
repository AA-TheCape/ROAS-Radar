{
  "name": "roas-radar-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:dashboard": "npm --prefix dashboard ci --include=dev && npm --prefix dashboard run build",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:migrate:start": "node dist/src/db/migrate.js",
    "db:migrate:check": "node scripts/check-migrations.mjs",
    "loadtest:large-payloads": "node scripts/load-test-large-payloads.mjs",
    "db:verify-raw-payload-query-plans": "node scripts/verify-raw-payload-query-plans.mjs",
    "db:verify-identity-graph-query-plans": "node scripts/verify-identity-graph-query-plans.mjs",
    "dev": "tsx watch src/server.ts",
    "lint": "biome lint src scripts test",
    "lint:dashboard": "npm --prefix dashboard run lint",
    "ops:monitoring:apply": "sh infra/monitoring/apply.sh",
    "start:api": "node dist/src/server.js",
    "start:worker": "node dist/src/worker.js",
    "start:worker-service": "node dist/src/worker-service.js",
    "meta-ads:sync": "tsx src/meta-ads-worker.ts",
    "meta-ads:sync:start": "node dist/src/meta-ads-worker.js",
    "meta-ads:order-value": "tsx src/meta-order-value-worker.ts",
    "meta-ads:order-value:start": "node dist/src/meta-order-value-worker.js",
    "google-ads:sync": "tsx src/google-ads-worker.ts",
    "google-ads:sync:start": "node dist/src/google-ads-worker.js",
    "data-quality:check": "tsx src/data-quality-worker.ts",
    "data-quality:check:start": "node dist/src/data-quality-worker.js",
    "session-attribution:retention": "tsx src/session-attribution-retention-worker.ts",
    "session-attribution:retention:start": "node dist/src/session-attribution-retention-worker.js",
    "attribution:backfill-orders": "tsx src/admin/backfill-order-attribution.ts",
    "attribution:materialization:start": "node dist/src/order-attribution-materialization-worker.js",
    "identity:backfill-graph": "tsx src/admin/backfill-identity-graph.ts",
    "identity:backfill-graph:start": "node dist/src/identity-graph-backfill-worker.js",
    "dead-letters:replay": "tsx src/admin/replay-dead-letters.ts",
    "test": "node scripts/run-tests.mjs all",
    "test:all": "node scripts/run-tests.mjs all",
    "test:unit": "node scripts/run-tests.mjs unit",
    "test:integration": "node scripts/run-tests.mjs integration",
    "test:attribution": "node scripts/run-attribution-tests.mjs critical",
    "test:attribution:coverage": "node scripts/run-attribution-tests.mjs coverage",
    "test:dead-letters": "node --import tsx --test test/dead-letter-replay.test.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=22"
  }
}
