{
  "name": "roas-radar-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:dashboard": "npm --prefix dashboard run build",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:migrate:start": "node dist/db/migrate.js",
    "db:migrate:check": "node scripts/check-migrations.mjs",
    "dev": "tsx watch src/server.ts",
    "lint": "biome lint src scripts test",
    "lint:dashboard": "npm --prefix dashboard run lint",
    "ops:monitoring:apply": "sh infra/monitoring/apply.sh",
    "start:api": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "start:worker-service": "node dist/worker-service.js",
    "meta-ads:sync": "tsx src/meta-ads-worker.ts",
    "meta-ads:sync:start": "node dist/meta-ads-worker.js",
    "google-ads:sync": "tsx src/google-ads-worker.ts",
    "google-ads:sync:start": "node dist/google-ads-worker.js",
    "data-quality:check": "tsx src/data-quality-worker.ts",
    "data-quality:check:start": "node dist/data-quality-worker.js",
    "test": "node scripts/run-tests.mjs all",
    "test:unit": "node scripts/run-tests.mjs unit",
    "test:integration": "node scripts/run-tests.mjs integration"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
