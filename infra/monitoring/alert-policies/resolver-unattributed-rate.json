{
  "displayName": "ROAS Radar __ENVIRONMENT__ Resolver Unattributed Spike",
  "documentation": {
    "content": "Unattributed order outcomes spiked above the rollout threshold. Review tier distribution, fallthrough stages, and normalization-failure labels on the observability dashboard. Runbook: __RUNBOOK_URL_ATTRIBUTION_COMPLETENESS__",
    "mimeType": "text/markdown"
  },
  "combiner": "OR",
  "enabled": true,
  "severity": "WARNING",
  "notificationChannels": __ALERT_NOTIFICATION_CHANNELS__,
  "conditions": [
    {
      "displayName": "Unattributed outcomes exceed 20 orders in 15 minutes",
      "conditionThreshold": {
        "filter": "metric.type=\"logging.googleapis.com/user/roas_attribution_resolver_outcomes\" resource.type=\"cloud_run_revision\" metric.labels.attribution_tier=\"unattributed\"",
        "comparison": "COMPARISON_GT",
        "thresholdValue": 20,
        "duration": "900s",
        "aggregations": [
          {
            "alignmentPeriod": "900s",
            "perSeriesAligner": "ALIGN_SUM",
            "crossSeriesReducer": "REDUCE_SUM",
            "groupByFields": [
              "metric.labels.pipeline"
            ]
          }
        ],
        "trigger": {
          "count": 1
        }
      }
    }
  ]
}
