{
  "displayName": "ROAS Radar __ENVIRONMENT__ Shopify Writeback Failures",
  "documentation": {
    "content": "Shopify attribution attribute writeback is failing during reconciliation or backfill. Runbook: __RUNBOOK_URL_ATTRIBUTION_COMPLETENESS__",
    "mimeType": "text/markdown"
  },
  "combiner": "OR",
  "enabled": true,
  "severity": "WARNING",
  "notificationChannels": __ALERT_NOTIFICATION_CHANNELS__,
  "alertStrategy": {
    "notificationRateLimit": {
      "period": "3600s"
    }
  },
  "conditions": [
    {
      "displayName": "Shopify writeback failure is emitted",
      "conditionMatchedLog": {
        "filter": "resource.type=\"cloud_run_revision\" AND (jsonPayload.event=\"order_attribution_backfill_shopify_writeback_failed\" OR jsonPayload.event=\"shopify_writeback_failed\")"
      }
    }
  ]
}
