{
  "displayName": "ROAS Radar __ENVIRONMENT__ Ingestion Errors",
  "documentation": {
    "content": "Investigate `/track` or Shopify webhook ingestion failures. Runbook: __RUNBOOK_URL_INGESTION__",
    "mimeType": "text/markdown"
  },
  "combiner": "OR",
  "enabled": true,
  "severity": "WARNING",
  "notificationChannels": __ALERT_NOTIFICATION_CHANNELS__,
  "conditions": [
    {
      "displayName": "Ingestion errors exceed 5 in 10 minutes",
      "conditionThreshold": {
        "filter": "metric.type=\"logging.googleapis.com/user/roas_ingestion_errors\" resource.type=\"cloud_run_revision\"",
        "comparison": "COMPARISON_GT",
        "thresholdValue": 5,
        "duration": "600s",
        "aggregations": [
          {
            "alignmentPeriod": "600s",
            "perSeriesAligner": "ALIGN_SUM"
          }
        ],
        "trigger": {
          "count": 1
        }
      }
    }
  ]
}
