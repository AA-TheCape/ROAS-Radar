{
  "displayName": "ROAS Radar __ENVIRONMENT__ Attribution Backlog",
  "documentation": {
    "content": "The attribution worker backlog is growing beyond the batch target or jobs are sitting too long. Runbook: __RUNBOOK_URL_ATTRIBUTION__",
    "mimeType": "text/markdown"
  },
  "combiner": "OR",
  "enabled": true,
  "severity": "CRITICAL",
  "notificationChannels": __ALERT_NOTIFICATION_CHANNELS__,
  "conditions": [
    {
      "displayName": "Pending attribution jobs exceed 100 for 15 minutes",
      "conditionThreshold": {
        "filter": "metric.type=\"logging.googleapis.com/user/roas_attribution_job_backlog\" resource.type=\"cloud_run_revision\"",
        "comparison": "COMPARISON_GT",
        "thresholdValue": 100,
        "duration": "900s",
        "aggregations": [
          {
            "alignmentPeriod": "300s",
            "perSeriesAligner": "ALIGN_MAX"
          }
        ],
        "trigger": {
          "count": 1
        }
      }
    },
    {
      "displayName": "Oldest pending job age exceeds 900 seconds for 15 minutes",
      "conditionThreshold": {
        "filter": "metric.type=\"logging.googleapis.com/user/roas_attribution_job_oldest_age_seconds\" resource.type=\"cloud_run_revision\"",
        "comparison": "COMPARISON_GT",
        "thresholdValue": 900,
        "duration": "900s",
        "aggregations": [
          {
            "alignmentPeriod": "300s",
            "perSeriesAligner": "ALIGN_MAX"
          }
        ],
        "trigger": {
          "count": 1
        }
      }
    }
  ]
}
