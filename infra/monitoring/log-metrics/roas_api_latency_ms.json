{
	"name": "roas_api_latency_ms",
	"description": "Distribution of request latencies emitted by the API middleware.",
	"filter": "resource.type=\"cloud_run_revision\" AND jsonPayload.event=\"http_request_completed\"",
	"valueExtractor": "EXTRACT(jsonPayload.durationMs)",
	"labelExtractors": {
		"service": "EXTRACT(jsonPayload.service)",
		"path": "EXTRACT(jsonPayload.path)",
		"method": "EXTRACT(jsonPayload.method)",
		"status_class": "EXTRACT(jsonPayload.statusClass)"
	},
	"metricDescriptor": {
		"metricKind": "DELTA",
		"valueType": "DISTRIBUTION",
		"unit": "ms",
		"displayName": "ROAS Radar API Latency",
		"labels": [
			{
				"key": "service",
				"valueType": "STRING",
				"description": "Service name."
			},
			{
				"key": "path",
				"valueType": "STRING",
				"description": "Normalized request path."
			},
			{
				"key": "method",
				"valueType": "STRING",
				"description": "HTTP method."
			},
			{
				"key": "status_class",
				"valueType": "STRING",
				"description": "Response status class."
			}
		]
	},
	"bucketOptions": {
		"explicitBuckets": {
			"bounds": [50, 100, 250, 500, 1000, 1500, 2500, 5000]
		}
	}
}
