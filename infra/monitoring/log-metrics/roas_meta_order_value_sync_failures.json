{
  "name": "roas_meta_order_value_sync_failures",
  "description": "Counts failed Meta order-value sync connections.",
  "filter": "resource.type=\"cloud_run_revision\" AND jsonPayload.event=\"meta_ads_order_value_sync_connection_failed\"",
  "labelExtractors": {
    "service": "EXTRACT(jsonPayload.service)",
    "trigger_source": "EXTRACT(jsonPayload.triggerSource)",
    "code": "EXTRACT(jsonPayload.code)"
  },
  "metricDescriptor": {
    "metricKind": "DELTA",
    "valueType": "INT64",
    "unit": "1",
    "displayName": "ROAS Radar Meta Order Value Sync Failures",
    "labels": [
      { "key": "service", "valueType": "STRING", "description": "Service emitting the failure." },
      { "key": "trigger_source", "valueType": "STRING", "description": "Why the sync ran." },
      { "key": "code", "valueType": "STRING", "description": "Normalized failure code." }
    ]
  }
}
