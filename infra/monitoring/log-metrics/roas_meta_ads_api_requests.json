{
  "name": "roas_meta_ads_api_requests",
  "description": "Counts Meta Ads API requests emitted by sync telemetry, partitioned by outcome and transaction source.",
  "filter": "resource.type=\"cloud_run_revision\" AND jsonPayload.event=(\"meta_ads_api_request_completed\" OR \"meta_ads_api_request_failed\")",
  "labelExtractors": {
    "service": "EXTRACT(jsonPayload.service)",
    "transaction_source": "EXTRACT(jsonPayload.transactionSource)",
    "outcome": "EXTRACT(jsonPayload.outcome)",
    "status_class": "EXTRACT(jsonPayload.statusClass)"
  },
  "metricDescriptor": {
    "metricKind": "DELTA",
    "valueType": "INT64",
    "unit": "1",
    "displayName": "ROAS Radar Meta Ads API Requests",
    "labels": [
      { "key": "service", "valueType": "STRING", "description": "Service emitting the API request telemetry." },
      { "key": "transaction_source", "valueType": "STRING", "description": "Meta Ads sync transaction surface." },
      { "key": "outcome", "valueType": "STRING", "description": "success or error." },
      { "key": "status_class", "valueType": "STRING", "description": "HTTP status family or network_error." }
    ]
  }
}
