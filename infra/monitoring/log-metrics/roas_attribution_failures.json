{
  "name": "roas_attribution_failures",
  "description": "Counts attribution job failures that were retried or abandoned.",
  "filter": "resource.type=\"cloud_run_revision\" AND jsonPayload.event=\"attribution_job_failed\"",
  "labelExtractors": {
    "service": "EXTRACT(jsonPayload.service)",
    "worker_id": "EXTRACT(jsonPayload.workerId)"
  },
  "metricDescriptor": {
    "metricKind": "DELTA",
    "valueType": "INT64",
    "unit": "1",
    "displayName": "ROAS Radar Attribution Failures",
    "labels": [
      {
        "key": "service",
        "valueType": "STRING",
        "description": "Service emitting the failure."
      },
      {
        "key": "worker_id",
        "valueType": "STRING",
        "description": "Worker instance handling the job."
      }
    ]
  }
}
