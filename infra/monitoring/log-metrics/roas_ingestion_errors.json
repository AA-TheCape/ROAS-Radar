{
	"name": "roas_ingestion_errors",
	"description": "Counts rejected or failed ingestion events across /track and Shopify webhooks.",
	"filter": "resource.type=\"cloud_run_revision\" AND jsonPayload.event=(\"tracking_ingest_rejected\" OR \"tracking_ingest_failed\" OR \"shopify_webhook_rejected\" OR \"shopify_webhook_failed\")",
	"labelExtractors": {
		"service": "EXTRACT(jsonPayload.service)",
		"event": "EXTRACT(jsonPayload.event)",
		"code": "EXTRACT(jsonPayload.code)"
	},
	"metricDescriptor": {
		"metricKind": "DELTA",
		"valueType": "INT64",
		"unit": "1",
		"displayName": "ROAS Radar Ingestion Errors",
		"labels": [
			{
				"key": "service",
				"valueType": "STRING",
				"description": "Service emitting the ingestion error."
			},
			{
				"key": "event",
				"valueType": "STRING",
				"description": "Structured event name."
			},
			{
				"key": "code",
				"valueType": "STRING",
				"description": "Application error code when present."
			}
		]
	}
}
