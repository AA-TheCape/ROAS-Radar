{
  "name": "roas_ga4_ingestion_lag_alerts",
  "description": "Counts GA4 session attribution lag alerts when hourly ingestion falls behind threshold.",
  "filter": "resource.type=\"cloud_run_revision\" AND jsonPayload.event=\"ga4_session_attribution_ingestion_lag_alert\"",
  "labelExtractors": {
    "service": "EXTRACT(jsonPayload.service)",
    "pipeline": "EXTRACT(jsonPayload.pipeline)",
    "lag_status": "EXTRACT(jsonPayload.lagStatus)"
  },
  "metricDescriptor": {
    "metricKind": "DELTA",
    "valueType": "INT64",
    "unit": "1",
    "displayName": "ROAS Radar GA4 Ingestion Lag Alerts",
    "labels": [
      { "key": "service", "valueType": "STRING", "description": "Service emitting the lag alert." },
      { "key": "pipeline", "valueType": "STRING", "description": "GA4 ingestion pipeline name." },
      { "key": "lag_status", "valueType": "STRING", "description": "Lag classification for the pipeline." }
    ]
  }
}
