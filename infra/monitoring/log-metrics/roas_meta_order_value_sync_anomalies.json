{
  "name": "roas_meta_order_value_sync_anomalies",
  "description": "Counts Meta order-value sync anomaly events such as zero-row pulls or sudden null spikes.",
  "filter": "resource.type=\"cloud_run_revision\" AND jsonPayload.event=\"meta_ads_order_value_sync_anomaly\"",
  "labelExtractors": {
    "service": "EXTRACT(jsonPayload.service)",
    "anomaly_type": "EXTRACT(jsonPayload.anomalyType)",
    "severity": "EXTRACT(jsonPayload.severity)",
    "trigger_source": "EXTRACT(jsonPayload.triggerSource)"
  },
  "metricDescriptor": {
    "metricKind": "DELTA",
    "valueType": "INT64",
    "unit": "1",
    "displayName": "ROAS Radar Meta Order Value Sync Anomalies",
    "labels": [
      { "key": "service", "valueType": "STRING", "description": "Service emitting the anomaly." },
      { "key": "anomaly_type", "valueType": "STRING", "description": "Specific anomaly type." },
      { "key": "severity", "valueType": "STRING", "description": "Structured anomaly severity." },
      { "key": "trigger_source", "valueType": "STRING", "description": "Why the sync ran." }
    ]
  }
}
