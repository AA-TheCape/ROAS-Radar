{
  "name": "roas_attribution_job_oldest_age_seconds",
  "description": "Age in seconds of the oldest pending attribution job.",
  "filter": "resource.type=\"cloud_run_revision\" AND jsonPayload.event=\"attribution_backlog_snapshot\"",
  "valueExtractor": "EXTRACT(jsonPayload.oldestJobAgeSeconds)",
  "labelExtractors": {
    "service": "EXTRACT(jsonPayload.service)",
    "worker_id": "EXTRACT(jsonPayload.workerId)"
  },
  "metricDescriptor": {
    "metricKind": "GAUGE",
    "valueType": "INT64",
    "unit": "s",
    "displayName": "ROAS Radar Attribution Oldest Job Age",
    "labels": [
      {
        "key": "service",
        "valueType": "STRING",
        "description": "Service name."
      },
      {
        "key": "worker_id",
        "valueType": "STRING",
        "description": "Worker instance."
      }
    ]
  }
}
