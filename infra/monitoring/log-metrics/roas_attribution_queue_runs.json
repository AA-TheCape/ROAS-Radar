{
  "name": "roas_attribution_queue_runs",
  "description": "Tracks worker queue throughput for claimed, succeeded, and failed attribution jobs.",
  "filter": "resource.type=\"cloud_run_revision\" AND jsonPayload.event=\"attribution_queue_outcome\"",
  "labelExtractors": {
    "service": "EXTRACT(jsonPayload.service)",
    "outcome": "EXTRACT(jsonPayload.outcome)"
  },
  "metricDescriptor": {
    "metricKind": "DELTA",
    "valueType": "INT64",
    "unit": "1",
    "displayName": "ROAS Radar Attribution Queue Runs",
    "labels": [
      {
        "key": "service",
        "valueType": "STRING",
        "description": "Service name."
      },
      {
        "key": "outcome",
        "valueType": "STRING",
        "description": "Queue outcome dimension."
      }
    ]
  }
}
