{
  "displayName": "__DASHBOARD_DISPLAY_NAME__",
  "mosaicLayout": {
    "columns": 12,
    "tiles": [
      {
        "xPos": 0,
        "yPos": 0,
        "width": 3,
        "height": 4,
        "widget": {
          "title": "Ingestion Errors",
          "scorecard": {
            "timeSeriesQuery": {
              "timeSeriesFilter": {
                "filter": "metric.type=\"logging.googleapis.com/user/roas_ingestion_errors\" resource.type=\"cloud_run_revision\"",
                "aggregation": {
                  "alignmentPeriod": "600s",
                  "perSeriesAligner": "ALIGN_SUM"
                }
              }
            },
            "sparkChartView": {
              "sparkChartType": "SPARK_LINE"
            }
          }
        }
      },
      {
        "xPos": 3,
        "yPos": 0,
        "width": 3,
        "height": 4,
        "widget": {
          "title": "Attribution Failures",
          "scorecard": {
            "timeSeriesQuery": {
              "timeSeriesFilter": {
                "filter": "metric.type=\"logging.googleapis.com/user/roas_attribution_failures\" resource.type=\"cloud_run_revision\"",
                "aggregation": {
                  "alignmentPeriod": "900s",
                  "perSeriesAligner": "ALIGN_SUM"
                }
              }
            },
            "sparkChartView": {
              "sparkChartType": "SPARK_LINE"
            }
          }
        }
      },
      {
        "xPos": 6,
        "yPos": 0,
        "width": 3,
        "height": 4,
        "widget": {
          "title": "P95 API Latency (ms)",
          "scorecard": {
            "timeSeriesQuery": {
              "timeSeriesFilter": {
                "filter": "metric.type=\"logging.googleapis.com/user/roas_api_latency_ms\" resource.type=\"cloud_run_revision\"",
                "aggregation": {
                  "alignmentPeriod": "600s",
                  "perSeriesAligner": "ALIGN_PERCENTILE_95"
                }
              }
            },
            "sparkChartView": {
              "sparkChartType": "SPARK_LINE"
            }
          }
        }
      },
      {
        "xPos": 9,
        "yPos": 0,
        "width": 3,
        "height": 4,
        "widget": {
          "title": "Queue Throughput",
          "scorecard": {
            "timeSeriesQuery": {
              "timeSeriesFilter": {
                "filter": "metric.type=\"logging.googleapis.com/user/roas_attribution_queue_runs\" resource.type=\"cloud_run_revision\" metric.label.outcome=\"claimed\"",
                "aggregation": {
                  "alignmentPeriod": "600s",
                  "perSeriesAligner": "ALIGN_SUM"
                }
              }
            },
            "sparkChartView": {
              "sparkChartType": "SPARK_LINE"
            }
          }
        }
      },
      {
        "xPos": 0,
        "yPos": 4,
        "width": 6,
        "height": 4,
        "widget": {
          "title": "API Latency by Route",
          "xyChart": {
            "dataSets": [
              {
                "plotType": "LINE",
                "legendTemplate": "{{metric.label.path}}",
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "metric.type=\"logging.googleapis.com/user/roas_api_latency_ms\" resource.type=\"cloud_run_revision\" metric.label.service=\"roas-radar-api\"",
                    "aggregation": {
                      "alignmentPeriod": "600s",
                      "perSeriesAligner": "ALIGN_PERCENTILE_95",
                      "crossSeriesReducer": "REDUCE_NONE",
                      "groupByFields": [
                        "metric.label.path"
                      ]
                    }
                  }
                }
              }
            ],
            "timeshiftDuration": "0s",
            "yAxis": {
              "label": "ms",
              "scale": "LINEAR"
            }
          }
        }
      },
      {
        "xPos": 6,
        "yPos": 4,
        "width": 6,
        "height": 4,
        "widget": {
          "title": "Ingestion and Attribution Error Trend",
          "xyChart": {
            "dataSets": [
              {
                "plotType": "STACKED_BAR",
                "legendTemplate": "Ingestion errors",
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "metric.type=\"logging.googleapis.com/user/roas_ingestion_errors\" resource.type=\"cloud_run_revision\"",
                    "aggregation": {
                      "alignmentPeriod": "600s",
                      "perSeriesAligner": "ALIGN_SUM"
                    }
                  }
                }
              },
              {
                "plotType": "STACKED_BAR",
                "legendTemplate": "Attribution failures",
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "metric.type=\"logging.googleapis.com/user/roas_attribution_failures\" resource.type=\"cloud_run_revision\"",
                    "aggregation": {
                      "alignmentPeriod": "600s",
                      "perSeriesAligner": "ALIGN_SUM"
                    }
                  }
                }
              }
            ],
            "timeshiftDuration": "0s",
            "yAxis": {
              "label": "events",
              "scale": "LINEAR"
            }
          }
        }
      },
      {
        "xPos": 0,
        "yPos": 8,
        "width": 6,
        "height": 4,
        "widget": {
          "title": "Attribution Queue Throughput",
          "xyChart": {
            "dataSets": [
              {
                "plotType": "LINE",
                "legendTemplate": "Claimed jobs",
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "metric.type=\"logging.googleapis.com/user/roas_attribution_queue_runs\" resource.type=\"cloud_run_revision\" metric.label.outcome=\"claimed\"",
                    "aggregation": {
                      "alignmentPeriod": "600s",
                      "perSeriesAligner": "ALIGN_SUM"
                    }
                  }
                }
              },
              {
                "plotType": "LINE",
                "legendTemplate": "Succeeded jobs",
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "metric.type=\"logging.googleapis.com/user/roas_attribution_queue_runs\" resource.type=\"cloud_run_revision\" metric.label.outcome=\"succeeded\"",
                    "aggregation": {
                      "alignmentPeriod": "600s",
                      "perSeriesAligner": "ALIGN_SUM"
                    }
                  }
                }
              },
              {
                "plotType": "LINE",
                "legendTemplate": "Failed jobs",
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "metric.type=\"logging.googleapis.com/user/roas_attribution_queue_runs\" resource.type=\"cloud_run_revision\" metric.label.outcome=\"failed\"",
                    "aggregation": {
                      "alignmentPeriod": "600s",
                      "perSeriesAligner": "ALIGN_SUM"
                    }
                  }
                }
              }
            ],
            "timeshiftDuration": "0s",
            "yAxis": {
              "label": "jobs",
              "scale": "LINEAR"
            }
          }
        }
      }
    ]
  }
}
