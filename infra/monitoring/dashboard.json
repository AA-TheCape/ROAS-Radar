{
  "displayName": "__DASHBOARD_DISPLAY_NAME__",
  "mosaicLayout": {
    "columns": 12,
    "tiles": [
      {
        "xPos": 0,
        "yPos": 0,
        "width": 12,
        "height": 2,
        "widget": {
          "title": "ROAS Radar observability",
          "text": {
            "content": "# __DASHBOARD_DISPLAY_NAME__\nDeploy-time dashboard for ingestion, attribution, API latency, and background job health.",
            "format": "MARKDOWN"
          }
        }
      },
      {
        "xPos": 0,
        "yPos": 2,
        "width": 4,
        "height": 4,
        "widget": {
          "title": "API latency p95 (10m)",
          "scorecard": {
            "timeSeriesQuery": {
              "timeSeriesFilter": {
                "filter": "metric.type=\"logging.googleapis.com/user/roas_api_latency_ms\" resource.type=\"cloud_run_revision\"",
                "aggregation": {
                  "alignmentPeriod": "600s",
                  "perSeriesAligner": "ALIGN_PERCENTILE_95",
                  "crossSeriesReducer": "REDUCE_MEAN"
                }
              },
              "unitOverride": "ms"
            },
            "sparkChartView": {
              "sparkChartType": "SPARK_LINE"
            }
          }
        }
      },
      {
        "xPos": 4,
        "yPos": 2,
        "width": 4,
        "height": 4,
        "widget": {
          "title": "Ingestion errors (10m)",
          "scorecard": {
            "timeSeriesQuery": {
              "timeSeriesFilter": {
                "filter": "metric.type=\"logging.googleapis.com/user/roas_ingestion_errors\" resource.type=\"cloud_run_revision\"",
                "aggregation": {
                  "alignmentPeriod": "600s",
                  "perSeriesAligner": "ALIGN_SUM",
                  "crossSeriesReducer": "REDUCE_SUM"
                }
              },
              "unitOverride": "1"
            },
            "sparkChartView": {
              "sparkChartType": "SPARK_BAR"
            }
          }
        }
      },
      {
        "xPos": 8,
        "yPos": 2,
        "width": 4,
        "height": 4,
        "widget": {
          "title": "Attribution failures (15m)",
          "scorecard": {
            "timeSeriesQuery": {
              "timeSeriesFilter": {
                "filter": "metric.type=\"logging.googleapis.com/user/roas_attribution_failures\" resource.type=\"cloud_run_revision\"",
                "aggregation": {
                  "alignmentPeriod": "900s",
                  "perSeriesAligner": "ALIGN_SUM",
                  "crossSeriesReducer": "REDUCE_SUM"
                }
              },
              "unitOverride": "1"
            },
            "sparkChartView": {
              "sparkChartType": "SPARK_BAR"
            }
          }
        }
      },
      {
        "xPos": 0,
        "yPos": 6,
        "width": 4,
        "height": 4,
        "widget": {
          "title": "Data quality alerts (10m)",
          "scorecard": {
            "timeSeriesQuery": {
              "timeSeriesFilter": {
                "filter": "metric.type=\"logging.googleapis.com/user/roas_data_quality_alerts\" resource.type=\"cloud_run_revision\"",
                "aggregation": {
                  "alignmentPeriod": "600s",
                  "perSeriesAligner": "ALIGN_SUM",
                  "crossSeriesReducer": "REDUCE_SUM"
                }
              },
              "unitOverride": "1"
            },
            "sparkChartView": {
              "sparkChartType": "SPARK_BAR"
            }
          }
        }
      },
      {
        "xPos": 4,
        "yPos": 6,
        "width": 4,
        "height": 4,
        "widget": {
          "title": "Order backfill failures (15m)",
          "scorecard": {
            "timeSeriesQuery": {
              "timeSeriesFilter": {
                "filter": "metric.type=\"logging.googleapis.com/user/roas_order_attribution_backfill_jobs\" resource.type=\"cloud_run_revision\" metric.labels.stage=\"failed\"",
                "aggregation": {
                  "alignmentPeriod": "900s",
                  "perSeriesAligner": "ALIGN_SUM",
                  "crossSeriesReducer": "REDUCE_SUM"
                }
              },
              "unitOverride": "1"
            },
            "sparkChartView": {
              "sparkChartType": "SPARK_BAR"
            }
          }
        }
      },
      {
        "xPos": 8,
        "yPos": 6,
        "width": 4,
        "height": 4,
        "widget": {
          "title": "Capture completeness",
          "scorecard": {
            "timeSeriesQuery": {
              "timeSeriesFilter": {
                "filter": "metric.type=\"logging.googleapis.com/user/roas_attribution_capture_completeness\" resource.type=\"cloud_run_revision\"",
                "aggregation": {
                  "alignmentPeriod": "600s",
                  "perSeriesAligner": "ALIGN_SUM",
                  "crossSeriesReducer": "REDUCE_SUM"
                }
              },
              "unitOverride": "1"
            },
            "sparkChartView": {
              "sparkChartType": "SPARK_BAR"
            }
          }
        }
      },
      {
        "xPos": 0,
        "yPos": 10,
        "width": 6,
        "height": 4,
        "widget": {
          "title": "Attribution Tier Counts",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "metric.type=\"logging.googleapis.com/user/roas_attribution_resolver_outcomes\" resource.type=\"cloud_run_revision\"",
                    "aggregation": {
                      "alignmentPeriod": "3600s",
                      "perSeriesAligner": "ALIGN_SUM",
                      "crossSeriesReducer": "REDUCE_SUM",
                      "groupByFields": [
                        "metric.labels.attribution_tier"
                      ]
                    }
                  }
                },
                "plotType": "STACKED_BAR",
                "targetAxis": "Y1"
              }
            ],
            "yAxis": {
              "label": "orders",
              "scale": "LINEAR"
            }
          }
        }
      },
      {
        "xPos": 6,
        "yPos": 10,
        "width": 6,
        "height": 4,
        "widget": {
          "title": "Resolver Fallthrough Stages",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "metric.type=\"logging.googleapis.com/user/roas_attribution_resolver_outcomes\" resource.type=\"cloud_run_revision\"",
                    "aggregation": {
                      "alignmentPeriod": "3600s",
                      "perSeriesAligner": "ALIGN_SUM",
                      "crossSeriesReducer": "REDUCE_SUM",
                      "groupByFields": [
                        "metric.labels.fallthrough_stage"
                      ]
                    }
                  }
                },
                "plotType": "STACKED_BAR",
                "targetAxis": "Y1"
              }
            ],
            "yAxis": {
              "label": "orders",
              "scale": "LINEAR"
            }
          }
        }
      },
      {
        "xPos": 0,
        "yPos": 14,
        "width": 6,
        "height": 4,
        "widget": {
          "title": "Unattributed Outcomes",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "metric.type=\"logging.googleapis.com/user/roas_attribution_resolver_outcomes\" resource.type=\"cloud_run_revision\" metric.labels.attribution_tier=\"unattributed\"",
                    "aggregation": {
                      "alignmentPeriod": "3600s",
                      "perSeriesAligner": "ALIGN_SUM",
                      "crossSeriesReducer": "REDUCE_SUM"
                    }
                  }
                },
                "plotType": "LINE",
                "targetAxis": "Y1"
              }
            ],
            "yAxis": {
              "label": "orders",
              "scale": "LINEAR"
            }
          }
        }
      },
      {
        "xPos": 6,
        "yPos": 14,
        "width": 6,
        "height": 4,
        "widget": {
          "title": "Unattributed By Reason",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "metric.type=\"logging.googleapis.com/user/roas_attribution_resolver_outcomes\" resource.type=\"cloud_run_revision\" metric.labels.attribution_tier=\"unattributed\"",
                    "aggregation": {
                      "alignmentPeriod": "3600s",
                      "perSeriesAligner": "ALIGN_SUM",
                      "crossSeriesReducer": "REDUCE_SUM",
                      "groupByFields": [
                        "metric.labels.first_normalization_failure_reason"
                      ]
                    }
                  }
                },
                "plotType": "STACKED_BAR",
                "targetAxis": "Y1"
              }
            ],
            "yAxis": {
              "label": "orders",
              "scale": "LINEAR"
            }
          }
        }
      },
      {
        "xPos": 0,
        "yPos": 18,
        "width": 6,
        "height": 4,
        "widget": {
          "title": "Resolver Outcomes By Pipeline",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "metric.type=\"logging.googleapis.com/user/roas_attribution_resolver_outcomes\" resource.type=\"cloud_run_revision\"",
                    "aggregation": {
                      "alignmentPeriod": "3600s",
                      "perSeriesAligner": "ALIGN_SUM",
                      "crossSeriesReducer": "REDUCE_SUM",
                      "groupByFields": [
                        "metric.labels.pipeline"
                      ]
                    }
                  }
                },
                "plotType": "STACKED_BAR",
                "targetAxis": "Y1"
              }
            ],
            "yAxis": {
              "label": "orders",
              "scale": "LINEAR"
            }
          }
        }
      },
      {
        "xPos": 6,
        "yPos": 18,
        "width": 6,
        "height": 4,
        "widget": {
          "title": "Capture Completeness By Source",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "metric.type=\"logging.googleapis.com/user/roas_attribution_capture_completeness\" resource.type=\"cloud_run_revision\"",
                    "aggregation": {
                      "alignmentPeriod": "3600s",
                      "perSeriesAligner": "ALIGN_SUM",
                      "crossSeriesReducer": "REDUCE_SUM",
                      "groupByFields": [
                        "metric.labels.source",
                        "metric.labels.capture_status"
                      ]
                    }
                  }
                },
                "plotType": "STACKED_BAR",
                "targetAxis": "Y1"
              }
            ],
            "yAxis": {
              "label": "events",
              "scale": "LINEAR"
            }
          }
        }
      }
    ]
  }
}
