ENVIRONMENT=production

GCP_PROJECT_ID=roas-radar-production
GCP_REGION=us-central1
GCP_SCHEDULER_REGION=us-central1
ARTIFACT_REGISTRY_REPOSITORY=roas-radar

API_SERVICE_NAME=roas-radar-api-production
DASHBOARD_SERVICE_NAME=roas-radar-dashboard-production
WORKER_SERVICE_NAME=roas-radar-worker-production
MIGRATOR_JOB_NAME=roas-radar-migrator-production
META_ADS_METADATA_JOB_NAME=roas-radar-meta-ads-metadata-refresh-production
GOOGLE_ADS_METADATA_JOB_NAME=roas-radar-google-ads-metadata-refresh-production

API_SERVICE_ACCOUNT_NAME=roas-radar-api-production
DASHBOARD_SERVICE_ACCOUNT_NAME=roas-radar-dashboard-production
WORKER_SERVICE_ACCOUNT_NAME=roas-radar-worker-production
MIGRATOR_JOB_SERVICE_ACCOUNT_NAME=roas-radar-migrator-production
META_ADS_JOB_SERVICE_ACCOUNT_NAME=roas-radar-meta-ads-production
GOOGLE_ADS_JOB_SERVICE_ACCOUNT_NAME=roas-radar-google-ads-production
RETENTION_JOB_SERVICE_ACCOUNT_NAME=roas-radar-retention-production
DATA_QUALITY_JOB_SERVICE_ACCOUNT_NAME=roas-radar-data-quality-production
IDENTITY_GRAPH_BACKFILL_JOB_SERVICE_ACCOUNT_NAME=roas-radar-identity-backfill-production
ORDER_ATTRIBUTION_MATERIALIZATION_JOB_SERVICE_ACCOUNT_NAME=roas-radar-order-materialization-production
SCHEDULER_INVOKER_SERVICE_ACCOUNT_NAME=roas-radar-scheduler-production
DEPLOYER_SERVICE_ACCOUNT_NAME=roas-radar-deployer-production

API_SERVICE_CPU=2
API_SERVICE_MEMORY=1Gi
API_SERVICE_MIN_INSTANCES=1
API_SERVICE_MAX_INSTANCES=8
DASHBOARD_SERVICE_CPU=1
DASHBOARD_SERVICE_MEMORY=512Mi
DASHBOARD_SERVICE_MIN_INSTANCES=1
DASHBOARD_SERVICE_MAX_INSTANCES=3
WORKER_SERVICE_CPU=2
WORKER_SERVICE_MEMORY=1Gi
WORKER_SERVICE_MIN_INSTANCES=1
WORKER_SERVICE_MAX_INSTANCES=4
MIGRATOR_JOB_CPU=1
MIGRATOR_JOB_MEMORY=512Mi
MIGRATOR_JOB_TASK_TIMEOUT=1200s
MIGRATOR_JOB_MAX_RETRIES=0
METADATA_REFRESH_JOB_CPU=2
METADATA_REFRESH_JOB_MEMORY=1Gi
METADATA_REFRESH_JOB_TASK_TIMEOUT=3600s
METADATA_REFRESH_JOB_MAX_RETRIES=1

META_ADS_METADATA_SCHEDULER_NAME=roas-radar-meta-ads-metadata-production
META_ADS_METADATA_SCHEDULE=17 * * * *
META_ADS_METADATA_TIME_ZONE=Etc/UTC
META_ADS_METADATA_SCHEDULER_ENABLED=true
META_ADS_METADATA_REFRESH_REQUESTED_BY=scheduler-meta-ads-production@roas-radar

GOOGLE_ADS_METADATA_SCHEDULER_NAME=roas-radar-google-ads-metadata-production
GOOGLE_ADS_METADATA_SCHEDULE=47 * * * *
GOOGLE_ADS_METADATA_TIME_ZONE=Etc/UTC
GOOGLE_ADS_METADATA_SCHEDULER_ENABLED=true
GOOGLE_ADS_METADATA_REFRESH_REQUESTED_BY=scheduler-google-ads-production@roas-radar

ATTRIBUTION_WORKER_POLL_INTERVAL_MS=5000
ORDER_ATTRIBUTION_MATERIALIZATION_REQUESTED_BY=cloud-run-worker-production
DASHBOARD_REPORTING_TENANT_ID=roas-radar
MIGRATOR_DATABASE_SECRET_NAME=MIGRATOR_DATABASE_URL

API_ALLOWED_ORIGINS=https://roasradar.example
TRACKING_ALLOWED_ORIGINS=https://roasradar.example
SHOPIFY_APP_BASE_URL=https://api.roasradar.example
SHOPIFY_APP_POST_INSTALL_REDIRECT_URL=https://dashboard.roasradar.example
META_ADS_APP_ID=replace-with-production-meta-app-id
META_ADS_APP_BASE_URL=https://api.roasradar.example
GOOGLE_ADS_APP_BASE_URL=https://api.roasradar.example
GOOGLE_ADS_CLIENT_ID=replace-with-production-google-client-id
GOOGLE_ADS_CLIENT_SECRET=replace-with-production-google-client-secret
GOOGLE_ADS_DEVELOPER_TOKEN=replace-with-production-google-developer-token
