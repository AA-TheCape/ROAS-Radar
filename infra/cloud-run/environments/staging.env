GCP_PROJECT_ID="replace-me"
GCP_REGION="us-central1"
ARTIFACT_REGISTRY_REPOSITORY="roas-radar"

API_IMAGE_NAME="roas-radar-app"
DASHBOARD_IMAGE_NAME="roas-radar-dashboard"

API_SERVICE_NAME="roas-radar-api-staging"
ATTRIBUTION_WORKER_SERVICE_NAME="roas-radar-attribution-worker-staging"
DASHBOARD_SERVICE_NAME="roas-radar-dashboard-staging"
MIGRATION_JOB_NAME="roas-radar-migrate-staging"
META_ADS_SYNC_JOB_NAME="roas-radar-meta-ads-sync-staging"
GOOGLE_ADS_SYNC_JOB_NAME="roas-radar-google-ads-sync-staging"
GA4_INGESTION_JOB_NAME="roas-radar-ga4-session-attribution-staging"
GA4_INGESTION_SCHEDULER_JOB_NAME="roas-radar-ga4-session-attribution-scheduler-staging"

API_SERVICE_ACCOUNT_NAME="roas-radar-api-staging"
ATTRIBUTION_WORKER_SERVICE_ACCOUNT_NAME="roas-radar-attribution-worker-staging"
DASHBOARD_SERVICE_ACCOUNT_NAME="roas-radar-dashboard-staging"
MIGRATION_JOB_SERVICE_ACCOUNT_NAME="roas-radar-migrate-staging"
META_ADS_SYNC_JOB_SERVICE_ACCOUNT_NAME="roas-radar-meta-ads-sync-staging"
GOOGLE_ADS_SYNC_JOB_SERVICE_ACCOUNT_NAME="roas-radar-google-ads-sync-staging"
GA4_INGESTION_JOB_SERVICE_ACCOUNT_NAME="roas-radar-ga4-ingestion-staging"
GA4_INGESTION_SCHEDULER_SERVICE_ACCOUNT_NAME="roas-radar-ga4-scheduler-staging"

DATABASE_URL_SECRET_NAME="DATABASE_URL"
REPORTING_API_TOKEN_SECRET_NAME="REPORTING_API_TOKEN"

API_SECRET_BINDINGS="DATABASE_URL=DATABASE_URL:latest,REPORTING_API_TOKEN=REPORTING_API_TOKEN:latest"
ATTRIBUTION_WORKER_SECRET_BINDINGS="DATABASE_URL=DATABASE_URL:latest,REPORTING_API_TOKEN=REPORTING_API_TOKEN:latest"
MIGRATION_JOB_SECRET_BINDINGS="DATABASE_URL=DATABASE_URL:latest"
META_ADS_SYNC_SECRET_BINDINGS="DATABASE_URL=DATABASE_URL:latest"
GOOGLE_ADS_SYNC_SECRET_BINDINGS="DATABASE_URL=DATABASE_URL:latest"
GA4_INGESTION_SECRET_BINDINGS="DATABASE_URL=DATABASE_URL:latest"

API_ENV_VARS="NODE_ENV=production"
ATTRIBUTION_WORKER_ENV_VARS="NODE_ENV=production,ATTRIBUTION_WORKER_LOOP=true"
DASHBOARD_ENV_VARS="NODE_ENV=production"
MIGRATION_JOB_ENV_VARS="NODE_ENV=production"
META_ADS_SYNC_ENV_VARS="NODE_ENV=production"
GOOGLE_ADS_SYNC_ENV_VARS="NODE_ENV=production"
GA4_INGESTION_ENV_VARS="NODE_ENV=production,GA4_BIGQUERY_ENABLED=true,GA4_INGESTION_REQUESTED_BY=cloud-run-scheduler-staging,GA4_INGESTION_BATCH_SIZE=6,GA4_INGESTION_MAX_RETRIES=5,GA4_INGESTION_INITIAL_BACKOFF_SECONDS=300,GA4_INGESTION_MAX_BACKOFF_SECONDS=21600,GA4_INGESTION_STALE_LOCK_MINUTES=30"

API_ALLOW_UNAUTHENTICATED="true"
API_INGRESS="all"
ATTRIBUTION_WORKER_ALLOW_UNAUTHENTICATED="false"
ATTRIBUTION_WORKER_INGRESS="internal"
DASHBOARD_ALLOW_UNAUTHENTICATED="true"
DASHBOARD_INGRESS="all"

CLOUDSQL_INSTANCE_CONNECTION_NAME=""
VPC_CONNECTOR_NAME=""
RUNTIME_CPU="1"
RUNTIME_MEMORY="1Gi"
RUNTIME_TIMEOUT_SECONDS="900"

GA4_INGESTION_SCHEDULE="5 * * * *"
GA4_INGESTION_SCHEDULER_TIME_ZONE="Etc/UTC"

OBSERVABILITY_DASHBOARD_DISPLAY_NAME="ROAS Radar - Staging"
RUNBOOK_BASE_URL="https://github.com/AA-TheCape/ROAS-Radar/blob/main/docs/runbooks"
ALERT_NOTIFICATION_CHANNELS=""
