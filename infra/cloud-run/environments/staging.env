ENVIRONMENT=staging

GCP_PROJECT_ID=roas-radar-staging
GCP_REGION=us-central1
GCP_SCHEDULER_REGION=us-central1
ARTIFACT_REGISTRY_REPOSITORY=roas-radar

API_SERVICE_NAME=roas-radar-api-staging
DASHBOARD_SERVICE_NAME=roas-radar-dashboard-staging
WORKER_SERVICE_NAME=roas-radar-worker-staging
MIGRATOR_JOB_NAME=roas-radar-migrator-staging
META_ADS_METADATA_JOB_NAME=roas-radar-meta-ads-metadata-refresh-staging
GOOGLE_ADS_METADATA_JOB_NAME=roas-radar-google-ads-metadata-refresh-staging

API_SERVICE_ACCOUNT_NAME=roas-radar-api-staging
DASHBOARD_SERVICE_ACCOUNT_NAME=roas-radar-dashboard-staging
WORKER_SERVICE_ACCOUNT_NAME=roas-radar-worker-staging
MIGRATOR_JOB_SERVICE_ACCOUNT_NAME=roas-radar-migrator-staging
META_ADS_JOB_SERVICE_ACCOUNT_NAME=roas-radar-meta-ads-staging
GOOGLE_ADS_JOB_SERVICE_ACCOUNT_NAME=roas-radar-google-ads-staging
RETENTION_JOB_SERVICE_ACCOUNT_NAME=roas-radar-retention-staging
DATA_QUALITY_JOB_SERVICE_ACCOUNT_NAME=roas-radar-data-quality-staging
IDENTITY_GRAPH_BACKFILL_JOB_SERVICE_ACCOUNT_NAME=roas-radar-identity-backfill-staging
ORDER_ATTRIBUTION_MATERIALIZATION_JOB_SERVICE_ACCOUNT_NAME=roas-radar-order-materialization-staging
SCHEDULER_INVOKER_SERVICE_ACCOUNT_NAME=roas-radar-scheduler-staging
DEPLOYER_SERVICE_ACCOUNT_NAME=roas-radar-deployer-staging

API_SERVICE_CPU=1
API_SERVICE_MEMORY=512Mi
API_SERVICE_MIN_INSTANCES=0
API_SERVICE_MAX_INSTANCES=4
DASHBOARD_SERVICE_CPU=1
DASHBOARD_SERVICE_MEMORY=512Mi
DASHBOARD_SERVICE_MIN_INSTANCES=0
DASHBOARD_SERVICE_MAX_INSTANCES=2
WORKER_SERVICE_CPU=1
WORKER_SERVICE_MEMORY=512Mi
WORKER_SERVICE_MIN_INSTANCES=0
WORKER_SERVICE_MAX_INSTANCES=2
MIGRATOR_JOB_CPU=1
MIGRATOR_JOB_MEMORY=512Mi
MIGRATOR_JOB_TASK_TIMEOUT=900s
MIGRATOR_JOB_MAX_RETRIES=0
METADATA_REFRESH_JOB_CPU=1
METADATA_REFRESH_JOB_MEMORY=512Mi
METADATA_REFRESH_JOB_TASK_TIMEOUT=2700s
METADATA_REFRESH_JOB_MAX_RETRIES=0

META_ADS_METADATA_SCHEDULER_NAME=roas-radar-meta-ads-metadata-staging
META_ADS_METADATA_SCHEDULE=17 */3 * * *
META_ADS_METADATA_TIME_ZONE=Etc/UTC
META_ADS_METADATA_SCHEDULER_ENABLED=true
META_ADS_METADATA_REFRESH_REQUESTED_BY=scheduler-meta-ads-staging@roas-radar

GOOGLE_ADS_METADATA_SCHEDULER_NAME=roas-radar-google-ads-metadata-staging
GOOGLE_ADS_METADATA_SCHEDULE=47 */3 * * *
GOOGLE_ADS_METADATA_TIME_ZONE=Etc/UTC
GOOGLE_ADS_METADATA_SCHEDULER_ENABLED=true
GOOGLE_ADS_METADATA_REFRESH_REQUESTED_BY=scheduler-google-ads-staging@roas-radar

ATTRIBUTION_WORKER_POLL_INTERVAL_MS=5000
ORDER_ATTRIBUTION_MATERIALIZATION_REQUESTED_BY=cloud-run-worker-staging
DASHBOARD_REPORTING_TENANT_ID=roas-radar
MIGRATOR_DATABASE_SECRET_NAME=MIGRATOR_DATABASE_URL

API_ALLOWED_ORIGINS=https://staging.roasradar.example
TRACKING_ALLOWED_ORIGINS=https://staging.roasradar.example
SHOPIFY_APP_BASE_URL=https://api-staging.roasradar.example
SHOPIFY_APP_POST_INSTALL_REDIRECT_URL=https://dashboard-staging.roasradar.example
META_ADS_APP_ID=replace-with-staging-meta-app-id
META_ADS_APP_BASE_URL=https://api-staging.roasradar.example
GOOGLE_ADS_APP_BASE_URL=https://api-staging.roasradar.example
GOOGLE_ADS_CLIENT_ID=replace-with-staging-google-client-id
GOOGLE_ADS_CLIENT_SECRET=replace-with-staging-google-client-secret
GOOGLE_ADS_DEVELOPER_TOKEN=replace-with-staging-google-developer-token
