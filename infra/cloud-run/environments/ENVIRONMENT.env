ENVIRONMENT=ENVIRONMENT

GCP_PROJECT_ID=roas-radar-ENVIRONMENT
GCP_REGION=us-central1
GCP_SCHEDULER_REGION=us-central1
ARTIFACT_REGISTRY_REPOSITORY=roas-radar

API_SERVICE_NAME=roas-radar-api-ENVIRONMENT
DASHBOARD_SERVICE_NAME=roas-radar-dashboard-ENVIRONMENT
WORKER_SERVICE_NAME=roas-radar-worker-ENVIRONMENT
MIGRATOR_JOB_NAME=roas-radar-migrator-ENVIRONMENT
META_ADS_METADATA_JOB_NAME=roas-radar-meta-ads-metadata-refresh-ENVIRONMENT
GOOGLE_ADS_METADATA_JOB_NAME=roas-radar-google-ads-metadata-refresh-ENVIRONMENT

API_SERVICE_ACCOUNT_NAME=roas-radar-api-ENVIRONMENT
DASHBOARD_SERVICE_ACCOUNT_NAME=roas-radar-dashboard-ENVIRONMENT
WORKER_SERVICE_ACCOUNT_NAME=roas-radar-worker-ENVIRONMENT
MIGRATOR_JOB_SERVICE_ACCOUNT_NAME=roas-radar-migrator-ENVIRONMENT
META_ADS_JOB_SERVICE_ACCOUNT_NAME=roas-radar-meta-ads-ENVIRONMENT
GOOGLE_ADS_JOB_SERVICE_ACCOUNT_NAME=roas-radar-google-ads-ENVIRONMENT
RETENTION_JOB_SERVICE_ACCOUNT_NAME=roas-radar-retention-ENVIRONMENT
DATA_QUALITY_JOB_SERVICE_ACCOUNT_NAME=roas-radar-data-quality-ENVIRONMENT
IDENTITY_GRAPH_BACKFILL_JOB_SERVICE_ACCOUNT_NAME=roas-radar-identity-backfill-ENVIRONMENT
ORDER_ATTRIBUTION_MATERIALIZATION_JOB_SERVICE_ACCOUNT_NAME=roas-radar-order-materialization-ENVIRONMENT
SCHEDULER_INVOKER_SERVICE_ACCOUNT_NAME=roas-radar-scheduler-ENVIRONMENT
DEPLOYER_SERVICE_ACCOUNT_NAME=roas-radar-deployer-ENVIRONMENT

API_SERVICE_CPU=1
API_SERVICE_MEMORY=512Mi
API_SERVICE_MIN_INSTANCES=0
API_SERVICE_MAX_INSTANCES=4
DASHBOARD_SERVICE_CPU=1
DASHBOARD_SERVICE_MEMORY=512Mi
DASHBOARD_SERVICE_MIN_INSTANCES=0
DASHBOARD_SERVICE_MAX_INSTANCES=2
WORKER_SERVICE_CPU=1
WORKER_SERVICE_MEMORY=512Mi
WORKER_SERVICE_MIN_INSTANCES=0
WORKER_SERVICE_MAX_INSTANCES=2
MIGRATOR_JOB_CPU=1
MIGRATOR_JOB_MEMORY=512Mi
MIGRATOR_JOB_TASK_TIMEOUT=900s
MIGRATOR_JOB_MAX_RETRIES=0
METADATA_REFRESH_JOB_CPU=1
METADATA_REFRESH_JOB_MEMORY=512Mi
METADATA_REFRESH_JOB_TASK_TIMEOUT=3600s
METADATA_REFRESH_JOB_MAX_RETRIES=0

META_ADS_METADATA_SCHEDULER_NAME=roas-radar-meta-ads-metadata-ENVIRONMENT
META_ADS_METADATA_SCHEDULE=17 * * * *
META_ADS_METADATA_TIME_ZONE=Etc/UTC
META_ADS_METADATA_SCHEDULER_ENABLED=false
META_ADS_METADATA_REFRESH_REQUESTED_BY=scheduler-meta-ads-ENVIRONMENT@roas-radar

GOOGLE_ADS_METADATA_SCHEDULER_NAME=roas-radar-google-ads-metadata-ENVIRONMENT
GOOGLE_ADS_METADATA_SCHEDULE=47 * * * *
GOOGLE_ADS_METADATA_TIME_ZONE=Etc/UTC
GOOGLE_ADS_METADATA_SCHEDULER_ENABLED=false
GOOGLE_ADS_METADATA_REFRESH_REQUESTED_BY=scheduler-google-ads-ENVIRONMENT@roas-radar

ATTRIBUTION_WORKER_POLL_INTERVAL_MS=5000
ORDER_ATTRIBUTION_MATERIALIZATION_REQUESTED_BY=cloud-run-worker
DASHBOARD_REPORTING_TENANT_ID=roas-radar
MIGRATOR_DATABASE_SECRET_NAME=MIGRATOR_DATABASE_URL

API_ALLOWED_ORIGINS=https://ENVIRONMENT.roasradar.example
TRACKING_ALLOWED_ORIGINS=https://ENVIRONMENT.roasradar.example
SHOPIFY_APP_BASE_URL=https://api-ENVIRONMENT.roasradar.example
SHOPIFY_APP_POST_INSTALL_REDIRECT_URL=https://dashboard-ENVIRONMENT.roasradar.example
META_ADS_APP_ID=replace-with-meta-app-id
META_ADS_APP_BASE_URL=https://api-ENVIRONMENT.roasradar.example
GOOGLE_ADS_APP_BASE_URL=https://api-ENVIRONMENT.roasradar.example
GOOGLE_ADS_CLIENT_ID=replace-with-google-client-id
GOOGLE_ADS_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_ADS_DEVELOPER_TOKEN=replace-with-google-developer-token
