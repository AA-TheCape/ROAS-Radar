ENVIRONMENT=dev

GCP_PROJECT_ID=roas-radar-dev
GCP_REGION=us-central1
GCP_SCHEDULER_REGION=us-central1
ARTIFACT_REGISTRY_REPOSITORY=roas-radar

API_SERVICE_NAME=roas-radar-api-dev
DASHBOARD_SERVICE_NAME=roas-radar-dashboard-dev
WORKER_SERVICE_NAME=roas-radar-worker-dev
MIGRATOR_JOB_NAME=roas-radar-migrator-dev
META_ADS_METADATA_JOB_NAME=roas-radar-meta-ads-metadata-refresh-dev
GOOGLE_ADS_METADATA_JOB_NAME=roas-radar-google-ads-metadata-refresh-dev

API_SERVICE_ACCOUNT_NAME=roas-radar-api-dev
DASHBOARD_SERVICE_ACCOUNT_NAME=roas-radar-dashboard-dev
WORKER_SERVICE_ACCOUNT_NAME=roas-radar-worker-dev
MIGRATOR_JOB_SERVICE_ACCOUNT_NAME=roas-radar-migrator-dev
META_ADS_JOB_SERVICE_ACCOUNT_NAME=roas-radar-meta-ads-dev
GOOGLE_ADS_JOB_SERVICE_ACCOUNT_NAME=roas-radar-google-ads-dev
RETENTION_JOB_SERVICE_ACCOUNT_NAME=roas-radar-retention-dev
DATA_QUALITY_JOB_SERVICE_ACCOUNT_NAME=roas-radar-data-quality-dev
IDENTITY_GRAPH_BACKFILL_JOB_SERVICE_ACCOUNT_NAME=roas-radar-identity-backfill-dev
ORDER_ATTRIBUTION_MATERIALIZATION_JOB_SERVICE_ACCOUNT_NAME=roas-radar-order-materialization-dev
SCHEDULER_INVOKER_SERVICE_ACCOUNT_NAME=roas-radar-scheduler-dev
DEPLOYER_SERVICE_ACCOUNT_NAME=roas-radar-deployer-dev

API_SERVICE_CPU=1
API_SERVICE_MEMORY=512Mi
API_SERVICE_MIN_INSTANCES=0
API_SERVICE_MAX_INSTANCES=2
DASHBOARD_SERVICE_CPU=1
DASHBOARD_SERVICE_MEMORY=512Mi
DASHBOARD_SERVICE_MIN_INSTANCES=0
DASHBOARD_SERVICE_MAX_INSTANCES=1
WORKER_SERVICE_CPU=1
WORKER_SERVICE_MEMORY=512Mi
WORKER_SERVICE_MIN_INSTANCES=0
WORKER_SERVICE_MAX_INSTANCES=1
MIGRATOR_JOB_CPU=1
MIGRATOR_JOB_MEMORY=512Mi
MIGRATOR_JOB_TASK_TIMEOUT=900s
MIGRATOR_JOB_MAX_RETRIES=0
METADATA_REFRESH_JOB_CPU=1
METADATA_REFRESH_JOB_MEMORY=512Mi
METADATA_REFRESH_JOB_TASK_TIMEOUT=1800s
METADATA_REFRESH_JOB_MAX_RETRIES=0

META_ADS_METADATA_SCHEDULER_NAME=roas-radar-meta-ads-metadata-dev
META_ADS_METADATA_SCHEDULE=17 */6 * * *
META_ADS_METADATA_TIME_ZONE=Etc/UTC
META_ADS_METADATA_SCHEDULER_ENABLED=false
META_ADS_METADATA_REFRESH_REQUESTED_BY=scheduler-meta-ads-dev@roas-radar

GOOGLE_ADS_METADATA_SCHEDULER_NAME=roas-radar-google-ads-metadata-dev
GOOGLE_ADS_METADATA_SCHEDULE=47 */6 * * *
GOOGLE_ADS_METADATA_TIME_ZONE=Etc/UTC
GOOGLE_ADS_METADATA_SCHEDULER_ENABLED=false
GOOGLE_ADS_METADATA_REFRESH_REQUESTED_BY=scheduler-google-ads-dev@roas-radar

ATTRIBUTION_WORKER_POLL_INTERVAL_MS=5000
ORDER_ATTRIBUTION_MATERIALIZATION_REQUESTED_BY=cloud-run-worker-dev
DASHBOARD_REPORTING_TENANT_ID=roas-radar
MIGRATOR_DATABASE_SECRET_NAME=MIGRATOR_DATABASE_URL

API_ALLOWED_ORIGINS=http://localhost:5173,https://dev.roasradar.example
TRACKING_ALLOWED_ORIGINS=http://localhost:5173,https://dev.roasradar.example
SHOPIFY_APP_BASE_URL=https://api-dev.roasradar.example
SHOPIFY_APP_POST_INSTALL_REDIRECT_URL=https://dashboard-dev.roasradar.example
META_ADS_APP_ID=replace-with-dev-meta-app-id
META_ADS_APP_BASE_URL=https://api-dev.roasradar.example
GOOGLE_ADS_APP_BASE_URL=https://api-dev.roasradar.example
GOOGLE_ADS_CLIENT_ID=replace-with-dev-google-client-id
GOOGLE_ADS_CLIENT_SECRET=replace-with-dev-google-client-secret
GOOGLE_ADS_DEVELOPER_TOKEN=replace-with-dev-google-developer-token
